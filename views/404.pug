  script(type="text/javascript").
    console.log(this.students);
    console.log(this.profs);
    jQuery(document).ready(function($) {
        calendar = $('#calendar').fullCalendar({
            header: {
                left: 'title',
                center: '',
                right: 'prev,next'
            },
            buttonIcons: {
                prev: 'prev fa-angle-left',
                next: 'next fa-angle-right',
            },
            selectable: true,
            eventLimit: true,
            events: !{JSON.stringify((systems || []).filter(function(s){ return s.id!=1 && s.id!=13 && s.id!=7 && s.id!=8; }).map(function(s){ return {title: s.phase, start: s.start_, end: s.end_}; }))}
        });
        $(window).trigger('xenon.resized');
    });
