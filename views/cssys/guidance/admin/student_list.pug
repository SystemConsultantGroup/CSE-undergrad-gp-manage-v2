block page_footer
  script(src="/cssys/assets/js/datatables/js/jquery.dataTables.min.js")
  script(src="/cssys/assets/js/datatables/dataTables.bootstrap.js")
  script(src="/cssys/assets/js/datatables/tabletools/dataTables.tableTools.min.js")
  script(src="/cssys/assets/js/select2/select2.min.js")
  script(src="/cssys/assets/js/datatables/fnReloadAjax.js")
  script(src="/cssys/assets/js/jquery.form.min.js")
  script.
    var dataList;
    jQuery(document).ready(function($) {
    $("#dataList select").select2({
    minimumResultsForSearch: -1
    });
    dataList=$("#dataList").DataTable({
    "oLanguage": {
    "sSearch": "검색 :",
    "sLengthMenu": "_MENU_ 명씩 보기",
    "sEmptyTable": "레코드가 없습니다.",
    "sInfo": "총 _TOTAL_명 중 _START_에서 _END_번째",
    "sInfoEmpty": "총 0명",
    "sZeroRecords": "일치하는 학생이 없습니다.",
    "sInfoFiltered": "(총 _MAX_명 중)",
    "oPaginate": {
    "sFirst": "처음",
    "sLast": "마지막",
    "sNext": "다음",
    "sPrevious": "이전"
    }
    },
    aLengthMenu: [
    [10, 25, 50, 100, -1],
    [10, 25, 50, 100, "전체"]
    ],
    //"sPaginationType": "full_numbers",
    // "bSort": true,
    "order": [[5, 'asc'], [7, 'desc'], [1, 'asc']],
    "bProcessing": true,
    "sAjaxSource": 'student_list/ajax/get_students',
    "sServerMethod": "POST",
    "aoColumns": [{
    "mData": "ids"
    }, {
    "mData": "name"
    }, {
    "mData": "email"
    }, {
    "mData": "phone"
    }, {
    "mData": "major",
    "mRender": function(data, type, full) {
    if(data>=0 && data<6) return ['전자전기공학부', '컴퓨터공학과', '반도체시스템공학과', '소프트웨어학과', '정보통신대학', '인터랙션사이언스학과'][data];
    else return "(미지정)";
    }
    }, /*{
    "mData": "Student.term",
    "mRender": function(data, type, full) {
    return data+"학기";
    }
    },*/ {
    "mData": "Student.status",
    "mRender": function(data, type, full) {
    if(data==0) return '<div style="font-size:0;">0</div>'+'재학';
    else if(data==1) return '<div style="font-size:0;">1</div>'+'휴학';
    else if(data==2) return '<div style="font-size:0;">2</div>'+'수료';
    else if(data==3) return '<div style="font-size:0;">3</div>'+'졸업';
    return "";
    }
    }, {
    "mData": "Student.Prof.User.name",
    "mRender": function(data, type, full) {
    if (data !== null ) {
    if(full.Student) {
    if(full.Student.state === 2) return '<div id="state2" style="font-size:0;">2</div>' + data + ' <div class="label label-blue">배정 완료</div>';
    else if(full.Student.state === 1) return '<div id="state1" style="font-size:0;">1</div>' + data + ' <div class="label label-success">신청 중</div>';
    else if(full.Student.state === 0) return ' <div id="state0" class="label label-danger">미배정</div>';
    else return ' <div id="state0" class="label label-danger">미배정</div>';
    } else return ' <div id="state0" class="label label-danger">미배정</div>';
    } else return ' <div id="state0" class="label label-danger">미배정</div>';
    }
    }, {
    "mData": "Student.updatedAt",
    "mRender": function(data, type, full) {
    if(full.Student.state === 2) return data;
    else return "-";
    }
    }],
    "fnRowCallback": function(nRow, aData, iDisplayIndex) {
    $(nRow).unbind("click").click(function() {
    document.location = "student/"+aData.id;
    });
    },
    "fnDrawCallback": function(oSettings) {
    $(window).trigger('xenon.resized');
    }
    });

    $('._filter').change(function(){
    $('input._filter,select._filter').each(function(index){
    dataList.column(index).search($(this).val()).draw();
    });
    });
    });
    function filter_excel_save(){
    var userArr=[];
    dataList.rows( { search:'applied' } ).data().each(function(value, index) {
    userArr.push(value.id);
    });
    $("#excel_save_frm input[name='arr']").val(JSON.stringify(userArr));
    $("#excel_save_frm").submit();
    }
