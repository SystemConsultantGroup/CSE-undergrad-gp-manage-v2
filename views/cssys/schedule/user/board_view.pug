extends layout

- var page = "board"

block page_header
  style.
    #name,#time,#views,#title {
      width: 100%;
      display: inline-block;
      padding-top: 7px;
      color: #373e4a;
    }
    #name,#time,#views {
      text-align: center;
    }
    #text {
      overflow-x: hidden;
    }
    .rotate{
      -ms-transform:rotate(180deg);
      -moz-transform:rotate(180deg);
      -webkit-transform:rotate(180deg);
      transform:rotate(180deg);
    }

block page_body
  .page-title
    .title-env
      h1.title 자유게시판
      p.description 일정관리시스템의 자유게시판 입니다.
    .breadcrumb-env
      ol.breadcrumb.bc-1
        li
          a(href="main")
            i.fa-home
            | 메인
        li.active
          strong 자유게시판
  .row
    .col-sm-12
      .panel.panel-default
        .panel-body
          form.form-horizontal(role="form")
            .form-group
              label.col-sm-2.control-label(for="ids") 작성자
              .col-sm-5
                span#name
              label.col-sm-1.control-label(for="ids") 작성
              .col-sm-2
                span#time
              label.col-sm-1.control-label(for="ids") 조회
              .col-sm-1
                span#views
            .form-group-separator
            .form-group
              label.col-sm-2.control-label(for="ids") 제목
              .col-sm-10
                span#title
            .form-group-separator
            .form-group(style="padding-left:15px;padding-right:15px;")
              #text
            .form-group-separator
            #files
            .form-group
              .col-sm-4
                a.btn.btn-primary#prev 이전글
                a.btn.btn-primary#next 다음글
              .col-sm-8(style="text-align:right;")
                a.btn.btn-white#modify(href="../modify/#{id}") 수정
                a.btn.btn-white#delete 삭제
                a.btn.btn-white#reply 답변
                a.btn.btn-white(href="../list") 목록
                a.btn.btn-success(href="../write") 글쓰기

block page_footer
  script(type="text/javascript").
    jQuery(document).ready(function($) {
      $.post( "/cssys/ajax/board/view/schedule_board/#{id}", function( data ) {
        if(data.result){
          $("#name").text(data.post.name);
          $("#time").text(data.post.time);
          $("#views").text(data.post.views);
          $("#title").html((data.post.notice?"[공지] ":(data.post.ParentId?"<i class='fa fa-reply rotate'></i> ":""))+data.post.title+(data.post.secret?" <i class='fa fa-lock'></i>":""));
          $("#text").html(data.post.text);
          for(var index in data.post.files){
            var size_;
            if(data.post.files[index].size>1024*1024) size_=(data.post.files[index].size/1024/1024).toFixed(1)+"M";
            else if(data.post.files[index].size>1024) size_=(data.post.files[index].size/1024).toFixed(1)+"K";
            else size_+"byte";
            $("#files").append(
              '<div class="form-group">'+
                '<label class="col-sm-2 control-label">첨부 파일 '+(parseInt(index)+1)+'</label>'+
                '<div class="col-sm-10">'+
                  '<a href="'+data.post.files[index].link+'">'+
                    '<span id="title"><i class="fa fa-file-o"></i> &nbsp;<b>'+data.post.files[index].name+'</b> &nbsp;('+size_+') &nbsp;'+data.post.files[index].downs+'회</span>'+
                  '</a>'+
                '</div>'+
              '</div>'
            );
          }
          if(data.prev==null) $("#prev").attr("disabled",true);
          else $("#prev").attr("href","../view/"+data.prev.id);
          if(data.next==null) $("#next").attr("disabled",true);
          else $("#next").attr("href","../view/"+data.next.id);
          if(data.post.UserId!=#{session().user.id}&&#{session().user.type}!=0) $("#modify, #delete").hide();
          if(data.post.notice) $("#reply").hide();
          $("#reply").attr("href","../reply/"+(data.post.ParentId?data.post.ParentId:data.post.id));
        }
        else{
          alert(data.text);
          window.history.back();
        }
      }).fail(function(){
        alert("존재하지 않는 글 입니다.");
        window.history.back();
      });
      $("#delete").click(function(){
        if(confirm("정말 삭제하시겠습니까?")){
          $.post( "/cssys/ajax/board/delete/schedule_board/#{id}", function( data ) {
            if(data.result){
              window.location.href = '../list';
            }
            else{
              alert(data.text);
            }
          }).fail(function(){
            alert("서버의 응답이 없습니다.");
          });
        }
      });
    });
