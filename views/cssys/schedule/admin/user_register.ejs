<%- include('../../../partials/head') %>
<% var page = "user_register"; %>
<link rel="stylesheet" href="/cssys/assets/js/select2/select2.css">
<link rel="stylesheet" href="/cssys/assets/js/select2/select2-bootstrap.css">
<style>
</style>

<div class="page-container">
  <div class="sidebar-menu toggle-others fixed">
    <%- include('./sidebar') %>
  </div>
  <div class="main-content">
    <%- include('../../../partials/navbar') %>

    <div class="page-title">
      <div class="title-env">
        <h1 class="title">사용자 등록 및 수정</h1>
        <p class="description">추가하고 싶은 사용자의 정보를 입력 또는 수정하고 싶은 사용자를 선택하시기 바랍니다.</p>
      </div>
      <div class="breadcrumb-env">
        <ol class="breadcrumb bc-1">
          <li>
            <a href="main">
              <i class="fa-home"></i>
              메인
            </a>
          </li>
          <li style="color:#979898;">사용자 관리</li>
          <li class="active">
            <strong>사용자 등록 및 수정</strong>
          </li>
        </ol>
      </div>
    </div>
    <div class="row">
      <div class="col-sm-12">
        <div class="panel panel-default">
          <div class="panel-body">
            <form id="register" class="form-horizontal" role="form">
              <div class="form-group">
                <label class="col-sm-2 control-label">사용자 선택</label>
                <div class="col-sm-10">
                  <select class="form-control" name="id">
                    <option></option>
                    <% users.forEach(function(user) { %>
                    <option value="<%= user.id %>"><%= user.name %></option>
                    <% }); %>
                  </select>
                </div>
              </div>
              <div class="form-group-separator"></div>
              <div class="form-group">
                <label class="col-sm-2 control-label" for="ids">아이디</label>
                <div class="col-sm-10">
                  <input class="form-control" type="text" name="ids" placeholder="ex) honggd" autocomplete="off">
                </div>
              </div>
              <div class="form-group-separator"></div>
              <div class="form-group">
                <label class="col-sm-2 control-label">비밀번호</label>
                <div class="col-sm-10">
                  <input class="form-control" type="password" name="password" placeholder="ex) abcd1234">
                </div>
              </div>
              <div class="form-group-separator"></div>
              <div class="form-group">
                <label class="col-sm-2 control-label">이름</label>
                <div class="col-sm-10">
                  <input class="form-control" type="text" name="name" placeholder="ex) 홍길동">
                </div>
              </div>
              <div class="form-group-separator"></div>
              <div class="form-group">
                <label class="col-sm-2 control-label">이메일</label>
                <div class="col-sm-10">
                  <input class="form-control" type="email" name="email" placeholder="ex) honggd@skku.edu">
                </div>
              </div>
              <div class="form-group-separator"></div>
              <div class="form-group">
                <label class="col-sm-2 control-label">연락처</label>
                <div class="col-sm-10">
                  <input class="form-control" type="text" name="phone" placeholder="ex) 031-290-1234">
                </div>
              </div>
              <div class="form-group-separator"></div>
              <div class="form-group">
                <div class="col-sm-10">
                  <h5 class="text-muted" id="deleteComment" style="display:none;">※ 사용자 삭제는 [사용자 관리] - [사용자 현황] 페이지에서 사용자 클릭 후 팝업창에서 할 수 있습니다.</h5>
                </div>
                <div class="col-sm-2">
                  <button class="btn btn-success" type="submit" style="float:right;">등록하기</button>
                </div>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>

    <%- include('./role-footer') %>
  </div>
</div>

<%- include('../../../partials/loading') %>
<%- include('../../../partials/foot-scripts') %>
<script src="/cssys/assets/js/select2/select2.min.js"></script>
<script type="text/javascript">
jQuery(document).ready(function($) {
  $("select[name='id']").select2({
    placeholder: '사용자를 선택해 주세요. (사용자 등록시 미선택)'
  }).on("select2-selecting", function(e) {
    $.post( "user_register/ajax/get_user",{id:e.val}, function( data ) {
      $('.form-group').removeClass('has-warning');
      $('input[name="ids"]').val(data.ids).attr("disabled", "disabled");;
      $('input[name="password"]').val("").attr('placeholder','(비밀번호 변경일 경우 입력)');
      $('input[name="name"]').val(data.name);
      $('input[name="email"]').val(data.email);
      $('input[name="phone"]').val(data.phone);
      $('button[type="submit"]').text('수정하기');
      $('#deleteComment').show();
    });
  });
  $("select[name='major']").select2({
    placeholder: '전공을 선택해 주세요.'
  });

  $('form#register').submit(function(e) {
        e.preventDefault();
        var flag = true;
        $(this).find("input.form-control").each(function(index) {
            if ($(this).val() === "") {
              if($('select[name="id"]').select2('val')=="" || $(this).attr("name")!="password"){
                  $(this).focus();
                  $(this).parent().parent().addClass('has-warning');
                  flag = false;
              }
            }
        });
        if (flag) {

          $('button[type="submit"]').attr("disabled", "disabled");
            show_loading_bar(70);
      $.post("user_register",{
        id : $('select[name="id"]').select2('val'),
        ids : $('input[name="ids"]').val(),
        password : $('input[name="password"]').val(),
        name : $('input[name="name"]').val(),
        email : $('input[name="email"]').val(),
        phone : $('input[name="phone"]').val()
      }, function(data) {
        show_loading_bar({
                      delay: 1,
                      pct: 100,
                      finish: function() {
                        if(!data.result){
                          alert(data.text);
                          window.location.href = './user_register';
                        }
                        else window.location.href = './user_list';
                      }
                  });
      });
        }
    });
});
</script>
<%- include('../../../partials/foot-end') %>
