<%- include('../partials/head') %>
<% var page = "login"; %>
<% var loginTitle_ = typeof loginTitle !== 'undefined' ? loginTitle : ''; %>
<% var loginPostUrl_ = typeof loginPostUrl !== 'undefined' ? loginPostUrl : '/cssys/login'; %>
<% var loginFailureMessage_ = typeof loginFailureMessage !== 'undefined' ? loginFailureMessage : '입력하신 아이디 혹은 패스워드가 잘못되었습니다. 다시 로그인해주세요.'; %>
<script>$('body').addClass('login-page');</script>
<style>
.login-footer {
    margin-top: 0px !important;
}
</style>

<div class="login-container">
  <div class="row">
    <div class="col-sm-12">
      <div class="errors-container"></div>
      <form id="login" class="login-form" method="post" role="form" style="max-width:500px;margin:0 auto;">
        <div class="login-header" style="text-align: center;">
          <a class="logo" href="https://cssys.skku.ac.kr/cssys">
            <img src="/cssys/assets/img/logo/logo_login.png" alt="SKKU ICC cssys">
          </a>
          <% if (loginTitle_) { %>
            <h4 style="margin-top: 20px; color: #fff;"><%= loginTitle_ %></h4>
          <% } %>
        </div>
        <div class="form-group">
          <label class="control-label" for="username" style="text-align:left;">아이디</label>
          <input id="ids" class="form-control input-dark" type="text" name="ids" autocomplete="off">
        </div>
        <div class="form-group">
          <label class="control-label" for="passwd" style="text-align:left;">비밀번호</label>
          <input id="password" class="form-control input-dark" type="password" name="password" autocomplete="off">
        </div>

        <div class="row">
          <div class="col-sm-6">
            <div class="form-group">
              <button class="btn btn-dark btn-block text-left" type="submit">
                <i class="fa-lock"></i> 로그인
              </button>
            </div>
          </div>
          <div class="col-sm-6">
            <div class="form-group">
              <button class="btn btn-dark btn-block text-left" type="button" onclick="javascript:alert('최초 비밀번호는 1111입니다. \n그 외 비밀번호 찾기는 행정실로 문의 부탁드립니다. \n\n소프트웨어학과사무실 sjy310@skku.edu / 031-299-4100')">
                <i class="fa-search"></i> 비밀번호 찾기
              </button>
            </div>
          </div>
        </div>

        <div class="login-footer">
          <div class="info-links">
            접속 IP : <%= ip %>
            <br>
            접속 시간 : <%= time %>
            <br>
          </div>
          <%- include('../partials/footer-policy-links') %>
        </div>
      </form>
    </div>
  </div>
</div>

<div class="modal fade" id="modalSelectMode" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" role="document">
    <div class="modal-content">
      <div class="modal-body">
        <div class="panel-heading" style="color: #333; font-size: 16px;">
          <strong>접속 시스템을 선택해주세요.</strong>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary" type="button" onclick="window.location.href='/cssys/work/'">연구논문/작품 시스템</button>
        <button class="btn btn-primary" type="button" style="margin-left: 0px;" onclick="alert('시스템 점검중입니다.')">생활지도 시스템</button>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/loading') %>
<%- include('../partials/foot-scripts') %>

<script src="/cssys/assets/js/jquery-validate/jquery.validate.min.js"></script>
<script src="/cssys/assets/js/toastr/toastr.min.js"></script>
<script type="text/javascript">
jQuery(document).ready(function($) {


    $("form#login").validate({
        rules: {
            ids: {
                required: true
            },
            password: {
                required: true
            }
        },
        messages: {
            ids: {
                required: '아이디를 입력해주세요.'
            },
            password: {
                required: '비밀번호를 입력해주세요.'
            }
        },
        submitHandler: function(form) {
            show_loading_bar(70);
            var opts = {
                "closeButton": true,
                "debug": false,
                "positionClass": "toast-top-full-width",
                "onclick": null,
                "showDuration": "300",
                "hideDuration": "1000",
                "timeOut": "5000",
                "extendedTimeOut": "1000",
                "showEasing": "swing",
                "hideEasing": "linear",
                "showMethod": "fadeIn",
                "hideMethod": "fadeOut"
            };

            $.ajax({
                url: <%- JSON.stringify(loginPostUrl_) %>,
                method: 'POST',
                dataType: 'json',
                data: {
                    ids: $(form).find('#ids').val(),
                    password: $(form).find('#password').val(),
                },
                success: function(res) {
                    show_loading_bar({
                        delay: 1,
                        pct: 100,
                        finish: function() {
                            if (res.result) {
                                if(res.type==3) window.location.href = '/cssys/schedule';
                                else {
                                    $('#modalSelectMode').modal('toggle');
                                    //window.location.href = '/cssys/work';
                                }
                            } else {
                                toastr.error(<%- JSON.stringify(loginFailureMessage_) %>, "로그인 실패!", opts);
                                $(form).find('#password').select();
                            }
                        }
                    });

                }
            });
        }
    });
    // Set Form focus
    $("form#login .form-group:has(.form-control):first .form-control").focus();
});
</script>
